rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regras temporárias permissivas para desenvolvimento e execução do SEED
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /booths/{boothId} {
      allow read: if true;
      allow write: if true; // Permite que o script de seed limpe e popule as barracas
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Permite que o script de seed limpe e popule os produtos
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if true;
    }
  }
}