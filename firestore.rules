
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para Barracas (Booths)
    match /booths/{boothId} {
      allow read: if true; // Leitura pública
      allow write: if request.auth != null && request.auth.uid == boothId; // Apenas o dono pode escrever
    }

    // Regras para Produtos (Products)
    match /products/{productId} {
      allow read: if true; // Leitura pública
      allow create: if request.auth != null && request.auth.uid == request.resource.data.sellerId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }
  }
}
